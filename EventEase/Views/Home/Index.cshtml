@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Home";
    var userRole = HttpContextAccessor.HttpContext.Session.GetString("UserRole");
}

<div class="text-center py-5 mb-5" style="background: var(--accent-color); border: 3px solid var(--text-color); border-radius: 30px; box-shadow: 10px 10px 0px var(--secondary-color);">
    <h1 class="display-4 fw-bold">✨ EventEase Venues</h1>
    <p class="lead fw-bold text-dark">Find the perfect space. Call <b>011-555-EVNT</b> to reserve your date!</p>
</div>

<div class="row g-4">
    <div class="col-md-@(userRole != null ? "4" : "6")">
        <div class="card h-100 border-3 p-3">
            <div class="card-body text-center">
                <h3 class="fw-bold">🏟️ Our Venues</h3>
                <p>View capacities and locations for our curated venues.</p>
                <a asp-controller="Venues" asp-action="Index" class="btn btn-primary w-100 mt-3">Browse Gallery</a>
            </div>
        </div>
    </div>

    <div class="col-md-@(userRole != null ? "4" : "6")">
        <div class="card h-100 border-3 p-3">
            <div class="card-body text-center">
                <h3 class="fw-bold">📅 Live Schedule</h3>
                <p>Check what events are happening and venue availability.</p>
                <a asp-controller="Events" asp-action="Index" class="btn btn-primary w-100 mt-3">View Calendar</a>
            </div>
        </div>
    </div>

    @if (userRole != null)
    {
        <div class="col-md-4">
            <div class="card h-100 border-3 p-3" style="background-color: #fff9db;">
                <div class="card-body text-center">
                    <h3 class="fw-bold text-danger">🛠️ Specialist Portal</h3>
                    <p>Logged in as: <b>@userRole</b></p>
                    <a asp-controller="Bookings" asp-action="Create" class="btn btn-dark w-100 mt-3">✨ Process New Booking</a>
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-5 p-4 text-center border-3" style="border: 3px dashed var(--text-color); border-radius: 20px;">
    <h4 class="fw-bold">Interested in a Venue?</h4>
    <p>Guests cannot book online. Please reach out to our specialists:</p>
    <div class="d-flex justify-content-center gap-4">
        <span>📧 <b>bookings@eventease.com</b></span>
        <span>📞 <b>+27 11 555 0123</b></span>
    </div>
</div>