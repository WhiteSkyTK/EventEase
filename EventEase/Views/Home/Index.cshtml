@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5 mb-5" style="background: var(--accent-color); border: 3px solid var(--text-color); border-radius: 30px; box-shadow: 10px 10px 0px var(--secondary-color);">
    <h1 class="display-4 fw-bold">Welcome to EventEase 🥳</h1>
    <p class="lead fw-bold text-dark">Simplifying your celebrations, one booking at a time.</p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100 border-3 p-3">
            <div class="card-body text-center">
                <h3 class="fw-bold">Explore Venues</h3>
                <p>Check capacity and locations for our whimsical spaces.</p>
                <a asp-controller="Venues" asp-action="Index" class="btn btn-primary w-100 mt-3">View Gallery</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 border-3 p-3">
            <div class="card-body text-center">
                <h3 class="fw-bold">Upcoming Events</h3>
                <p>See what's already scheduled to avoid date conflicts.</p>
                <a asp-controller="Events" asp-action="Index" class="btn btn-primary w-100 mt-3">View Schedule</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 border-3 p-3" style="background-color: #fff9db;">
            <div class="card-body text-center">
                <h3 class="fw-bold text-danger">Specialist Portal</h3>
                <p>Ready to finalize a booking? Start the process here.</p>
                <a asp-controller="Bookings" asp-action="Create" class="btn btn-dark w-100 mt-3">✨ New Booking</a>
            </div>
        </div>
    </div>
</div>