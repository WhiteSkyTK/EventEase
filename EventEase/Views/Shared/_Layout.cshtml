<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventEase</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EventEase.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="container-wrapper">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom border-3 mb-3" style="border-color: var(--text-color) !important;">
    <div class="container-fluid">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">✨ EventEase</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
            <ul class="navbar-nav flex-grow-1">
                <li class="nav-item">
                    <a class="nav-link fw-bold" asp-controller="Venues" asp-action="Index">🏟️ Venues</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link fw-bold" asp-controller="Events" asp-action="Index">📅 Events</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link fw-bold" asp-controller="Bookings" asp-action="Index">🎟️ Bookings</a>
                </li>
            </ul>
            <div class="d-flex">
                <a href="#" class="btn btn-outline-dark btn-sm">🔒 Specialist Login</a>
            </div>
        </div>
    </div>
</nav>
    </header>
        <main role="main" class="pb-3 container">
            @RenderBody()
        </main>
    </div>
    <footer class="footer mt-auto py-4 bg-white border-top border-3" style="border-color: var(--text-color) !important;">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <span class="fw-bold text-dark">© 2026 EventEase Portal</span>
                    <span class="ms-2 badge bg-accent text-dark border border-dark border-2" style="background-color: var(--accent-color);">Admin Access Only</span>
                </div>
                <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                    <a class="text-decoration-none text-dark fw-bold me-3" href="#">Privacy Policy</a>
                    <a class="text-decoration-none text-dark fw-bold" href="#">Support Desk</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
