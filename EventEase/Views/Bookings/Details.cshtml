@model EventEase.Models.Booking
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Booking Details";
    var userRole = HttpContextAccessor.HttpContext.Session.GetString("UserRole");
}

<div class="container py-4">
    <div class="card border-3 shadow-lg" style="border-radius: 25px; border: 3px solid #000; overflow: hidden;">
        <div class="card-header bg-primary text-white py-3">
            <h2 class="mb-0 fw-bold">🎟️ Booking Confirmation</h2>
        </div>
        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-6">
                    <h5 class="text-muted text-uppercase small fw-bold">Event Details</h5>
                    <p class="display-6 fw-bold text-dark">@Model.Event.EventName</p>
                    <p class="fs-5">📅 @Model.BookingDate.ToString("D")</p>
                </div>
                <div class="col-md-6">
                    <h5 class="text-muted text-uppercase small fw-bold">Venue Location</h5>
                    <p class="h3 fw-bold">📍 @Model.Venue.Location</p>
                    <p class="badge bg-warning text-dark border-2 border border-dark">Booking ID: #@Model.BookingId</p>
                </div>
            </div>

            <hr class="my-4 border-2">

            <div class="d-flex gap-3">
                <a asp-action="Index" class="btn btn-outline-dark fw-bold px-4 border-2 border-dark">← Back to List</a>

                @if (userRole == "Admin" || userRole == "Specialist")
                {
                    <a asp-action="Edit" asp-route-id="@Model.BookingId" class="btn btn-warning fw-bold px-4 border-2 border-dark">Edit</a>
                    <a asp-action="Delete" asp-route-id="@Model.BookingId" class="btn btn-danger fw-bold px-4 border-2 border-dark">Delete</a>
                }
            </div>
        </div>
    </div>
</div>