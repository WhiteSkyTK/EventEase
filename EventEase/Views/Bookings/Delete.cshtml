@model EventEase.Models.Booking

@{
    ViewData["Title"] = "Cancel Booking";
}

<div class="container py-4">
    <div class="card border-3 shadow-lg" style="border-radius: 25px; border: 3px solid #000; overflow: hidden;">
        <div class="card-header bg-danger text-white py-3">
            <h2 class="mb-0 fw-bold">⚠️ Cancel Reservation?</h2>
        </div>

        <div class="card-body p-4">
            <p class="fs-5 text-muted">Are you sure you want to delete this booking? This action cannot be undone.</p>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <h5 class="text-uppercase small fw-bold text-danger">Event</h5>
                    <p class="h4 fw-bold">@Model.Event.EventName</p>
                </div>
                <div class="col-md-6">
                    <h5 class="text-uppercase small fw-bold text-danger">Date</h5>
                    <p class="h4 fw-bold">@Model.BookingDate.ToLongDateString()</p>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="BookingId" />
                <div class="d-flex gap-3 mt-4">
                    <button type="submit" class="btn btn-danger btn-lg fw-bold px-5 border-2 border-dark" style="border-radius: 15px;">
                        Confirm Delete
                    </button>
                    <a asp-action="Index" class="btn btn-outline-dark btn-lg fw-bold px-5 border-2 border-dark" style="border-radius: 15px;">
                        Keep Booking
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>