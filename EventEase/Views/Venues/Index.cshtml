@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model IEnumerable<EventEase.Models.Venue>

@{
    ViewData["Title"] = "Venues Gallery";
    var userRole = HttpContextAccessor.HttpContext.Session.GetString("UserRole");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">🏟️ Our Whimsical Venues</h1>
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-3 shadow-sm mb-4" style="border-radius: 15px; border: 2px solid #000;">
            <strong>@TempData["Error"]</strong>
        </div>
    }
    @if (userRole == "Admin")
    {
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm" style="border-radius: 15px; border: 3px solid #000;">+ Add New Venue</a>
    }
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card h-100 border-3 shadow-sm" style="border-radius: 20px; overflow: hidden;">
                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://placehold.co/600x400?text=Venue+Coming+Soon" : item.ImageUrl)" class="card-img-top" style="height: 200px; object-fit: cover; border-bottom: 3px solid #000;">
                <div class="card-body">
                    <h4 class="fw-bold">@item.VenueName</h4>
                    <p class="text-muted">📍 @item.Location</p>
                    <div class="d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@item.VenueId" class="btn btn-sm btn-outline-dark fw-bold">Details</a>
                        @if (userRole == "Admin")
                        {
                            <a asp-action="Edit" asp-route-id="@item.VenueId" class="btn btn-sm btn-warning fw-bold border-2 border-dark">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.VenueId" class="btn btn-sm btn-danger fw-bold border-2 border-dark">Delete</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>