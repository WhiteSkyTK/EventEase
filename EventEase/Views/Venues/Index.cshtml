<table class="table table-hover">
    <thead>
        <tr>
            <th>Event Name</th>
            <th>Date</th>
            <th>Venue Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-bold">@item.EventName</td>
                <td>@item.EventDate.ToShortDateString()</td>
                <td>
                    @if (item.Venue != null)
                    {
                        <span class="status-badge status-confirmed">📍 @item.Venue.VenueName</span>
                    }
                    else
                    {
                        <span class="status-badge status-pending">⚠️ Venue Required</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.EventId" class="btn btn-sm btn-outline-dark">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>