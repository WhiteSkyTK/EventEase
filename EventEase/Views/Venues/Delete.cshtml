@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<div class="container py-4">
    <div class="card border-3 shadow-lg" style="border-radius: 25px; border: 3px solid #000; overflow: hidden;">
        <div class="card-header bg-danger text-white py-3">
            <h2 class="mb-0 fw-bold">🏟️ Remove Venue</h2>
        </div>

        <div class="card-body p-4 text-center">
            <img src="@Model.ImageUrl" class="img-fluid rounded border border-3 border-dark mb-4" style="max-height: 200px;">

            <h3 class="fw-bold">Delete "@Model.VenueName"?</h3>
            <p class="text-muted">This venue is located in <strong>@Model.Location</strong>.</p>

            <form asp-action="Delete" class="mt-4">
                <input type="hidden" asp-for="VenueId" />
                <div class="d-flex justify-content-center gap-3">
                    <input type="submit" value="Yes, Delete It" class="btn btn-danger btn-lg fw-bold px-4 border-2 border-dark" style="border-radius: 15px;" />
                    <a asp-action="Index" class="btn btn-outline-dark btn-lg fw-bold px-4 border-2 border-dark" style="border-radius: 15px;">No, Go Back</a>
                </div>
            </form>
        </div>
    </div>
</div>