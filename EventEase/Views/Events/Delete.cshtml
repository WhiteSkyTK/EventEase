@model EventEase.Models.Event

@{
    ViewData["Title"] = "Remove Event";
}

<div class="container py-4">
    <div class="card border-3 shadow-sm" style="border-radius: 25px; border: 3px solid #000; overflow: hidden;">
        <div class="card-header bg-dark text-white py-3">
            <h2 class="mb-0 fw-bold">🗑️ Delete Event</h2>
        </div>

        <div class="card-body p-4">
            <div class="alert alert-warning border-2 border-dark fw-bold">
                ⚠️ Warning: Deleting an event will also remove any associated bookings.
            </div>

            <dl class="row mt-4">
                <dt class="col-sm-3 text-muted">Event Name</dt>
                <dd class="col-sm-9 fw-bold h4">@Model.EventName</dd>

                <dt class="col-sm-3 text-muted">Location</dt>
                <dd class="col-sm-9">📍 @(Model.Venue?.Location ?? "TBA")</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="EventId" />
                <div class="d-flex gap-3 mt-4">
                    <input type="submit" value="Permanently Delete" class="btn btn-danger fw-bold border-2 border-dark" style="border-radius: 15px;" />
                    <a asp-action="Index" class="btn btn-outline-dark fw-bold border-2 border-dark" style="border-radius: 15px;">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>