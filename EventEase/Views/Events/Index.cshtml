@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model IEnumerable<EventEase.Models.Event>

@{
    ViewData["Title"] = "Event Schedule";
    var userRole = HttpContextAccessor.HttpContext.Session.GetString("UserRole");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold">📅 Scheduled Events</h1>
        <p class="text-muted">Check availability and upcoming whimsical gatherings.</p>
    </div>

    @if (userRole == "Admin")
    {
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm" style="border-radius: 15px;">
            ✨ Schedule New Event
        </a>
    }
</div>

<div class="card border-3 shadow-sm" style="border-radius: 20px; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="bg-dark text-white">
                <tr>
                    <th class="ps-4">Event Name</th>
                    <th>Description</th>
                    <th>Date & Time</th>
                    <th>Venue Location</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="vertical-align: middle;">
                        <td class="ps-4 fw-bold">@item.EventName</td>
                        <td>@item.Description</td>
                        <td>
                            <span class="badge bg-light text-dark border-2 border">
                                🕒 @item.EventDate.ToString("f")
                            </span>
                        </td>
                        <td>
                            <i class="bi bi-geo-alt-fill text-danger"></i>
                            @(item.Venue != null ? item.Venue.Location : "TBA")
                        </td>
                        <td class="text-center">
                            <div class="btn-group gap-2">
                                <a asp-action="Details" asp-route-id="@item.EventId" class="btn btn-sm btn-outline-dark">View</a>

                                @if (userRole == "Admin" || userRole == "Specialist")
                                {
                                    <a asp-action="Edit" asp-route-id="@item.EventId" class="btn btn-sm btn-warning">Edit</a>
                                }

                                @if (userRole == "Admin")
                                {
                                    <a asp-action="Delete" asp-route-id="@item.EventId" class="btn btn-sm btn-danger">Delete</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <h4 class="text-muted">No events scheduled yet. 🎈</h4>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-4">
    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-dark fw-bold">← Back to Home</a>
</div>