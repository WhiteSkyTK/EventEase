@model EventEase.Models.Event

@{
    ViewData["Title"] = "Schedule New Event";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">📅 Schedule an Event</h1>
        <a asp-action="Index" class="btn btn-outline-dark">← Back to List</a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-3 p-4" style="border-color: var(--text-color); border-radius: 20px;">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="EventName" class="form-label fw-bold">Event Name</label>
                        <input asp-for="EventName" class="form-control" placeholder="e.g. Smith Wedding Reception" />
                        <span asp-validation-for="EventName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Tell us about the event..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="form-group mb-3">
                            <label>Start Date & Time</label>
                            <input asp-for="StartDateTime" class="form-control" type="datetime-local" />
                        </div>

                        <div class="form-group mb-3">
                            <label>End Date & Time</label>
                            <input asp-for="EndDateTime" class="form-control" type="datetime-local" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="VenueId" class="form-label fw-bold">Assign Venue</label>
                            <select asp-for="VenueId" class="form-select border-3" asp-items="ViewBag.VenueId">
                                <option value="">-- Optional: Assign Later --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary btn-lg w-100 py-3">
                            ✨ Create Event
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}