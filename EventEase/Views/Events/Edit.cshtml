@model EventEase.Models.Event

@{
    ViewData["Title"] = "Modify Event";
}

<div class="container py-4">
    <div class="card border-3 shadow-sm" style="border-radius: 20px; border: 3px solid #000;">
        <div class="card-header bg-warning py-3">
            <h2 class="fw-bold mb-0">✏️ Modify Event</h2>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit">
                @* PLACE ERROR MESSAGE HERE *@
                <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger border-2 mb-3">@TempData["Error"]</div>
                }

                <input type="hidden" asp-for="EventId" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="EventName" class="fw-bold"></label>
                        <input asp-for="EventName" class="form-control border-2" />
                        <span asp-validation-for="EventName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="VenueId" class="fw-bold">Location</label>
                        <select asp-for="VenueId" class="form-control border-2" asp-items="ViewBag.VenueId"></select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="StartDateTime" class="fw-bold">Starts At</label>
                        <input asp-for="StartDateTime" class="form-control border-2" type="datetime-local" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="EndDateTime" class="fw-bold">Ends At</label>
                        <input asp-for="EndDateTime" class="form-control border-2" type="datetime-local" />
                    </div>

                    <div class="col-12 mb-3">
                        <label asp-for="Description" class="fw-bold"></label>
                        <textarea asp-for="Description" class="form-control border-2" rows="3"></textarea>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-dark btn-lg px-5 fw-bold" style="border-radius: 12px;">Update Event</button>
                    <a asp-action="Index" class="btn btn-outline-dark btn-lg px-4 ms-2" style="border-radius: 12px;">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-outline-dark fw-bold border-3 shadow-sm px-4" style="border-radius: 12px;">
        ⬅️ Return to List
    </a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
